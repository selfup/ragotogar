## Directory names used by the organizer (main.go) and sync scripts.
## Source this file from any script that needs these definitions.

PHOTO_DIRS=("JPEG" "HIF" "RAW")
VIDEO_DIRS=("MOV" "MP4" "BRAW" "NEV" "NDF")
AUDIO_DIRS=("AUDIO")

## Photo/image file extensions (used by exif_fix.sh)
PHOTO_EXTS=("jpg" "jpeg" "hif" "heif" "heic" "raf" "arw" "nef" "cr2" "cr3" "dng" "orf" "rw2" "pef")

## macOS junk files to exclude from sync operations
MACOS_EXCLUDES=("._*" ".DS_Store")
