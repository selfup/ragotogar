{
  "permissions": {
    "allow": [
      "Bash(go vet *)",
      "Bash(go test *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./*.env)",
      "Read(./**/*.env)",
      "Read(./**/.env.*)",
      "Bash(cat .env*)",
      "Bash(cat *.env*)",
      "Bash(head .env*)",
      "Bash(head *.env*)",
      "Bash(tail .env*)",
      "Bash(tail *.env*)",
      "Bash(less .env*)",
      "Bash(less *.env*)",
      "Bash(more .env*)",
      "Bash(more *.env*)",
      "Bash(bat .env*)",
      "Bash(bat *.env*)",
      "Bash(grep * .env*)",
      "Bash(grep * *.env*)",
      "Bash(rg * .env*)",
      "Bash(rg * *.env*)",
      "Bash(awk * .env*)",
      "Bash(awk * *.env*)",
      "Bash(sed * .env*)",
      "Bash(sed * *.env*)",
      "Bash(xxd .env*)",
      "Bash(xxd *.env*)",
      "Bash(strings .env*)",
      "Bash(strings *.env*)",
      "Bash(cp .env* *)",
      "Bash(cp *.env* *)",
      "Bash(mv .env* *)",
      "Bash(mv *.env* *)"
    ]
  }
}
